[Unit]
Description=Prepare DeepSeek Cursor Quick Tunnel and patch Cursor URL at login
Documentation=https://github.com/cheapjourney/deepseek-cursor-setup
After=network-online.target deepseek-cursor-proxy.service
Wants=network-online.target deepseek-cursor-proxy.service
Before=update-cursor-deepseek-url.service

[Service]
SuccessExitStatus=75
Type=oneshot
ExecStart=%h/.local/bin/deepseek-cursor-boot-prepare
StandardOutput=journal
StandardError=journal
SyslogIdentifier=deepseek-cursor-boot-prepare
TimeoutStartSec=900

[Install]
WantedBy=default.target
